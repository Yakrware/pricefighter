<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Launch theme only. All in-app styling is done with Material 3 in Compose.
      Parent is a platform DayNight theme so we don't need the Material View library.
    -->
    <style name="Theme.PriceFighter" parent="@android:style/Theme.DeviceDefault.DayNight">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>
